# Polyglot Dockerfile for Python AppHost E2E tests.
# Extends the shared polyglot base with Python and the uv package manager.

FROM aspire-e2e-polyglot-base

ARG UBUNTU_APT_MIRROR=

COPY tests/Shared/Docker/configure-ubuntu-apt-mirror.sh /usr/local/bin/
RUN sh /usr/local/bin/configure-ubuntu-apt-mirror.sh "$UBUNTU_APT_MIRROR"
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends python3 python3-pip python3-venv && \
    rm -rf /var/lib/apt/lists/* && \
    ln -sf /usr/bin/python3 /usr/local/bin/python

# Install uv (the package manager used by the Python AppHost scaffolding).
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"
