<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <SignAssembly>false</SignAssembly>

    <!-- Do not run tests in Helix at all -->
    <RunOnAzdoHelixWindows>false</RunOnAzdoHelixWindows>
    <RunOnAzdoHelixLinux>false</RunOnAzdoHelixLinux>
    <RunOnGithubActionsMacOS>true</RunOnGithubActionsMacOS>
  </PropertyGroup>

  <!-- The CLI bootstrap (Program.BuildApplicationAsync, PR1-S12) reads the AspireCliChannel
       AssemblyMetadata from Assembly.GetEntryAssembly(), which under `dotnet test` is this
       test host. In production the entry assembly is Aspire.Cli.dll with the metadata baked
       in by Aspire.Cli.csproj. Mirror that here so any test resolving CliExecutionContext
       from a real Program.BuildApplicationAsync host gets a coherent channel value. -->
  <ItemGroup>
    <AssemblyMetadata Include="AspireCliChannel" Value="daily" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Aspire.Cli\Aspire.Cli.csproj" />
    <ProjectReference Include="..\Aspire.TestUtilities\Aspire.TestUtilities.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.DotNet.RemoteExecutor" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.Testing" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="StreamJsonRpc" VersionOverride="$(StreamJsonRpcPackageVersionForCli)" />
    <PackageReference Include="Verify.XunitV3" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(TestsSharedDir)Logging\*.cs" LinkBase="shared/Logging" />
    <Compile Include="$(TestsSharedDir)TestModuleInitializer.cs" Link="shared/TestModuleInitializer.cs" />
    <Compile Include="$(TestsSharedDir)AsyncTestHelpers.cs" Link="shared/AsyncTestHelpers.cs" />
    <Compile Include="$(TestsSharedDir)TemporaryRepo.cs" Link="shared\TemporaryRepo.cs" />
    <Compile Include="$(TestsSharedDir)TempDirectory.cs" Link="shared\TempDirectory.cs" />
  </ItemGroup>

</Project>
