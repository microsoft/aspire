// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "yarn: install extension",
			"type": "shell",
			"command": "yarn install",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "watchers"
			},
			"problemMatcher": []
		},
		{
			"label": "extension: prepare",
			"type": "shell",
			"command": "yarn run generate-version && yarn run generate-schema && yarn run l10n:export && yarn run l10n:import",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"group": "watchers"
			},
			"problemMatcher": [],
			"dependsOn": [
				"yarn: install extension"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "extension: watch",
			"type": "shell",
			// Run webpack directly (not via `yarn run watch`) so its stdout
			// reaches VS Code's problem-matcher unmangled. Prepend a marker so
			// the matcher's beginsPattern always fires before webpack prints
			// "compiled", regardless of warning ordering.
			"command": "echo '[extension: watch] starting webpack' && ${workspaceFolder}/node_modules/.bin/webpack --watch",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "webpack",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^ERROR in (.*)$",
					"file": 1,
					"message": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "\\[extension: watch\\] starting webpack|^assets? by|^Recompil",
					"endsPattern": "^webpack [\\d.]+ compiled"
				}
			},
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"extension: prepare"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "extension: watch-tests",
			"type": "shell",
			"command": "${workspaceFolder}/node_modules/.bin/tsc -p . -w --outDir out",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"group": "watchers"
			},
			"group": "build",
			"dependsOn": [
				"extension: prepare"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "tasks: watch-tests extension",
			"dependsOn": [
				"extension: watch",
				"extension: watch-tests"
			],
			"problemMatcher": []
		}
	]
}


