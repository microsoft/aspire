// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "yarn: install extension",
			"type": "shell",
			"command": "yarn install",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "watchers"
			},
			"problemMatcher": []
		},
		{
			"label": "extension: prepare",
			"type": "shell",
			"command": "yarn run generate-version && yarn run generate-schema && yarn run l10n:export && yarn run l10n:import",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"group": "watchers"
			},
			"problemMatcher": [],
			"dependsOn": [
				"yarn: install extension"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "extension: watch",
			"type": "shell",
			// Invoke webpack directly so the $ts-webpack-watch problem matcher
			// can recognize the "compiled" line. Going through `yarn run watch`
			// triggers the prewatch lifecycle (which we run separately as
			// "extension: prepare") and mangles stdout so the matcher never
			// signals "ready", causing VS Code to hang on preLaunchTask.
			//
			// Keep this as the direct background task (not a compound wrapper).
			// VS Code's preLaunchTask requires the referenced task itself to be
			// the background task whose problemMatcher signals "ready"; wrapping
			// it in a compound breaks that signal and the debug session never
			// launches.
			"command": "${workspaceFolder}/node_modules/.bin/webpack --watch",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": "$ts-webpack-watch",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"extension: prepare"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "extension: watch-tests",
			"type": "shell",
			"command": "${workspaceFolder}/node_modules/.bin/tsc -p . -w --outDir out",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"group": "watchers"
			},
			"group": "build",
			"dependsOn": [
				"extension: prepare"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "tasks: watch-tests extension",
			"dependsOn": [
				"extension: watch",
				"extension: watch-tests"
			],
			"problemMatcher": []
		}
	]
}


