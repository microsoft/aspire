<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aspire-StarterApplication.1.ServiceDefaults\Aspire-StarterApplication.1.ServiceDefaults.csproj" />
  </ItemGroup>

{{#useRedisCache}}
  <ItemGroup>
    <PackageReference Include="Aspire.StackExchange.Redis.OutputCaching" Version="{{aspireVersion}}" />
  </ItemGroup>

{{/useRedisCache}}
</Project>
