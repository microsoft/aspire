@page "/structuredlogs"
@page "/structuredlogs/resource/{resourceName}"

@using System.Globalization
@using Aspire.Dashboard.Resources
@using Aspire.Dashboard.Components.Controls
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject IJSRuntime JS
@implements IDisposable

@inject IStringLocalizer<Dashboard.Resources.StructuredLogs> Loc
@inject IStringLocalizer<ControlsStrings> ControlsStringsLoc
@inject IStringLocalizer<StructuredFiltering> FilterLoc
@inject IStringLocalizer<Dialogs> DialogsLoc
@inject IStringLocalizer<AIPrompts> AIPromptsLoc

<PageTitle>
    <ApplicationName
        AdditionalText="@PageViewModel.SelectedResource.Id?.ReplicaSetName"
        ResourceName="@nameof(Dashboard.Resources.StructuredLogs.StructuredLogsPageTitle)"
        Loc="@Loc"/>
</PageTitle>

<div class="page">
    <div class="page__header">
        <div>
            <div class="page__title">@Loc[nameof(Dashboard.Resources.StructuredLogs.StructuredLogsHeader)]</div>
            <div class="page__subtitle">@((MarkupString)GetSubtitle())</div>
        </div>
        <div class="page__header-spacer"></div>

        <SearchBox Value="@_filter" ValueChanged="OnFilterChangedAsync"
                   Placeholder="@ControlsStringsLoc[nameof(ControlsStrings.FilterPlaceholder)]" />

        <button id="structuredLogsFilterButton" type="button"
                class="icon-btn @(ViewModel.Filters.Count == 0 ? string.Empty : "icon-btn--active")"
                @onclick="() => OpenFilterAsync(null)"
                title="@FilterLoc[nameof(StructuredFiltering.AddFilter)]"
                aria-label="@FilterLoc[nameof(StructuredFiltering.AddFilter)]">
            <DeckIcon Name="DeckIconName.Filter" Size="17" />
        </button>
    </div>

    <div class="page__toolbar deck-structured-toolbar">
        <ResourceSelect Resources="_resourceViewModels"
                        AriaLabel="@ControlsStringsLoc[nameof(ControlsStrings.SelectAResource)]"
                        @bind-SelectedResource="PageViewModel.SelectedResource"
                        @bind-SelectedResource:after="HandleSelectedResourceChangedAsync"
                        CanSelectGrouping="true"
                        LabelClass="toolbar-left" />

        <LogLevelSelect @bind-LogLevel="@PageViewModel.SelectedLogLevel"
                        LogLevels="@_logLevels"
                        HandleSelectedLogLevelChangedAsync="@HandleSelectedLogLevelChangedAsync" />

        @if (ViewModel.Filters.Count > 0)
        {
            <FluentCounterBadge Count="@(ViewModel.Filters.GetEnabledFilters().Count())" Appearance="Appearance.Accent">
                <AspireMenuButton HideIcon="true" Text="@FilterLoc[nameof(StructuredFiltering.Filters)]" Items="@GetFilterMenuItems()" />
            </FluentCounterBadge>
        }

        <div class="page__header-spacer"></div>

        <ExplainErrorsButton @ref="_explainErrorsButton" OnClick="ExplainErrorsAsync" HasErrors="@ViewModel.HasErrors()" />

        <SignalsActionsDisplay HandleClearSignal="@ClearStructureLogs"
                              IsPaused="@PauseManager.AreStructuredLogsPaused(out _)"
                              OnPausedChanged="@PauseManager.SetStructuredLogsPaused"
                              SelectedResource="@PageViewModel.SelectedResource" />
    </div>

    <div class="page__body" id="structured-logs-page-body-id">
        <div class="table-wrap deck-logs-table-wrap">
            <table class="data deck-logs-table">
                <thead>
                    <tr>
                        <th style="width: 200px;">@Loc[nameof(Dashboard.Resources.StructuredLogs.StructuredLogsResourceColumnHeader)]</th>
                        <th style="width: 120px;">@Loc[nameof(Dashboard.Resources.StructuredLogs.StructuredLogsLevelColumnHeader)]</th>
                        <th style="width: 140px;">@Loc[nameof(Dashboard.Resources.StructuredLogs.StructuredLogsTimestampColumnHeader)]</th>
                        <th>@Loc[nameof(Dashboard.Resources.StructuredLogs.StructuredLogsMessageColumnHeader)]</th>
                        <th style="width: 90px;">@Loc[nameof(Dashboard.Resources.StructuredLogs.StructuredLogsTraceColumnHeader)]</th>
                        <th style="width: 56px;" class="deck-logs-actions-col">@ControlsStringsLoc[nameof(ControlsStrings.ActionsColumnHeader)]</th>
                    </tr>
                </thead>
                <tbody>
                    @* Virtualize keeps the page responsive for large log volumes; the paged
                       ItemsProvider reuses the existing TelemetryRepository query. SpacerElement="tr"
                       keeps the virtualization spacers valid table rows. The scroll container is
                       the .page__body. *@
                    <Virtualize @ref="_logsGrid" ItemsProvider="@GetLogsAsync" ItemSize="46"
                                OverscanCount="20" SpacerElement="tr" Context="entry" TItem="OtlpLogEntry">
                        <ItemContent>
                            @{
                                var isSelected = entry.InternalId == PageViewModel.SelectedLogEntry?.LogEntry.InternalId;
                            }
                            <tr class="clickable @(isSelected ? "selected" : "") @GetSeverityRowClass(entry)" @key="entry.InternalId"
                                data-log-entry-id="@entry.InternalId"
                                @onclick="() => OnShowPropertiesAsync(entry, buttonId: null)">
                                <td>
                                    <span class="deck-log-resource" title="@GetResourceName(entry.ResourceView)"
                                          style="border-left-color: @(ColorGenerator.Instance.GetColorVariableByKey(GetResourceName(entry.ResourceView)));">
                                        @GetResourceName(entry.ResourceView)
                                    </span>
                                </td>
                                <td><span class="deck-log-level"><LogLevelColumnDisplay LogEntry="@entry" /></span></td>
                                <td>
                                    <span class="cell-mono cell-muted" title="@FormatHelpers.FormatDateTime(TimeProvider, entry.TimeStamp, MillisecondsDisplay.Full, CultureInfo.CurrentCulture)">
                                        @FormatHelpers.FormatTimeWithOptionalDate(TimeProvider, entry.TimeStamp, MillisecondsDisplay.Truncated)
                                    </span>
                                </td>
                                <td>
                                    <div class="deck-log-message">
                                        <LogMessageColumnDisplay FilterText="@(ViewModel.FilterText)" LogEntry="@entry" IsGenAILogCallback="@IsGenAILogEntry" LaunchGenAIVisualizerCallback="@LaunchGenAIVisualizerAsync" />
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(entry.TraceId))
                                    {
                                        <a href="@DashboardUrls.TraceDetailUrl(entry.TraceId, entry.SpanId)" class="cell-mono" @onclick:stopPropagation="true">
                                            @OtlpHelpers.ToShortenedId(entry.TraceId)
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="cell-muted">—</span>
                                    }
                                </td>
                                <td class="deck-logs-actions-col">
                                    <div class="grid-action-container" @onclick:stopPropagation="true">
                                        <StructuredLogActions LogEntry="@entry"
                                                              OnViewDetails="@((buttonId) => OnShowPropertiesAsync(entry, buttonId))" />
                                    </div>
                                </td>
                            </tr>
                        </ItemContent>
                        <EmptyContent>
                            <tr>
                                <td colspan="6">
                                    <EmptyState Title="@Loc[nameof(Dashboard.Resources.StructuredLogs.StructuredLogsNoLogsFound)]">
                                        <IconContent>
                                            <DeckIcon Name="DeckIconName.Logs" Size="22" />
                                        </IconContent>
                                    </EmptyState>
                                </td>
                            </tr>
                        </EmptyContent>
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Log details open in a Deck-style right-side drawer overlay. *@
@if (PageViewModel.SelectedLogEntry is { } selectedLogEntry)
{
    <Drawer OnClose="@(() => ClearSelectedLogEntryAsync(causedByUserAction: true))">
        <TitleContent>
            @StructureLogsDetailsViewModel.GetEventName(selectedLogEntry.LogEntry, Loc)
        </TitleContent>
        <SubtitleContent>
            @selectedLogEntry.LogEntry.Scope.Name
        </SubtitleContent>
        <ChildContent>
            <StructuredLogDetails ViewModel="selectedLogEntry" />
        </ChildContent>
    </Drawer>
}
