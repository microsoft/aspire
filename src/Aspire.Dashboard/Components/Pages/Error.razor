@page "/error"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject IStringLocalizer<Dashboard.Resources.Routes> Loc

<PageTitle>@Loc[nameof(Dashboard.Resources.Routes.ErrorHandlerPageTitle)]</PageTitle>

<div class="auth-backdrop">
    <div class="auth-card">
        <div class="auth-brand">
            <AspireLogo Height="64" Width="64" />
        </div>
        <h1 class="auth-title">@Loc[nameof(Dashboard.Resources.Routes.ErrorHandlerPageTitle)]</h1>
        <p class="auth-subtitle">@Loc[nameof(Dashboard.Resources.Routes.ErrorHandlerPageSubtitle)]</p>

        @if (ShowRequestId)
        {
            <div class="auth-meta">
                <span class="auth-meta-label">@Loc[nameof(Dashboard.Resources.Routes.ErrorHandlerPageRequestId)]</span>
                <code class="auth-meta-value">@RequestId</code>
            </div>
        }
    </div>
    <div class="auth-version">
        @VersionHelpers.DashboardDisplayVersion
    </div>
</div>
