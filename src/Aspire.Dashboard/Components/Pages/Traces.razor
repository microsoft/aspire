@page "/traces"
@page "/traces/resource/{resourceName}"

@using Aspire.Dashboard.Resources

@inject IStringLocalizer<Dashboard.Resources.Traces> Loc
@inject IStringLocalizer<StructuredFiltering> FilterLoc
@inject IStringLocalizer<ControlsStrings> ControlsStringsLoc
@inject IStringLocalizer<AIPrompts> AIPromptsLoc
@inject IStringLocalizer<Dialogs> DialogsLoc

@implements IDisposable

<PageTitle>
    <ApplicationName
        AdditionalText="@PageViewModel.SelectedResource.Id?.ReplicaSetName"
        ResourceName="@nameof(Dashboard.Resources.Traces.TracesPageTitle)"
        Loc="@Loc"/>
</PageTitle>

@{
    var subtitle = PauseText
        ?? (_hasLoaded
            ? $"{_totalItemsCount} {Loc[nameof(Dashboard.Resources.Traces.TracesHeader)].Value.ToLowerInvariant()}"
            : ControlsStringsLoc[nameof(ControlsStrings.Loading)].Value);
}

<div class="page">
    <div class="page__header">
        <div>
            <div class="page__title">@Loc[nameof(Dashboard.Resources.Traces.TracesHeader)]</div>
            <div class="page__subtitle">@subtitle</div>
        </div>
        <div class="page__header-spacer"></div>

        <div class="traces-toolbar">
            <ResourceSelect Resources="_resourceViewModels"
                            AriaLabel="@ControlsStringsLoc[nameof(ControlsStrings.SelectAResource)]"
                            @bind-SelectedResource="PageViewModel.SelectedResource"
                            @bind-SelectedResource:after="HandleSelectedResourceChanged"
                            CanSelectGrouping="true" />

            <SpanTypeSelect @bind-SpanType="@PageViewModel.SelectedSpanType"
                            SpanTypes="@_spanTypes"
                            HandleSelectedSpanTypeChangedAsync="@HandleSelectedSpanTypeChangedAsync" />

            <SearchBox Value="@_filter" ValueChanged="OnFilterChangedAsync"
                       Placeholder="@ControlsStringsLoc[nameof(ControlsStrings.FilterPlaceholder)]" />

            <button id="tracesFilterButton" type="button"
                    class="icon-btn @(TracesViewModel.Filters.Count == 0 ? string.Empty : "icon-btn--active")"
                    @onclick="() => OpenFilterAsync(null)"
                    title="@FilterLoc[nameof(StructuredFiltering.AddFilter)]"
                    aria-label="@FilterLoc[nameof(StructuredFiltering.AddFilter)]">
                <DeckIcon Name="DeckIconName.Filter" Size="17" />
            </button>
            @if (TracesViewModel.Filters.Count > 0)
            {
                <FluentCounterBadge HorizontalPosition="70" Count="@(TracesViewModel.Filters.GetEnabledFilters().Count())" Appearance="Appearance.Accent">
                    <AspireMenuButton ButtonAppearance="Appearance.Stealth" HideIcon="true"
                                      Icon="@(new Icons.Regular.Size20.Filter())"
                                      Items="@GetFilterMenuItems()"
                                      Title="@FilterLoc[nameof(StructuredFiltering.Filters)]" />
                </FluentCounterBadge>
            }

            <ExplainErrorsButton @ref="_explainErrorsButton" OnClick="ExplainErrorsAsync" HasErrors="@TracesViewModel.HasErrors()" />

            <SignalsActionsDisplay HandleClearSignal="@ClearTraces"
                                   IsPaused="@PauseManager.AreTracesPaused(out _)"
                                   OnPausedChanged="@PauseManager.SetTracesPaused"
                                   SelectedResource="@PageViewModel.SelectedResource" />
        </div>
    </div>

    <div class="page__body" id="traces-page-body-id">
        <div class="table-wrap">
            <table class="data traces-table">
                <thead>
                    <tr>
                        <th style="width: 150px;">@ControlsStringsLoc[nameof(ControlsStrings.TimestampColumnHeader)]</th>
                        <th style="width: 28%;">@ControlsStringsLoc[nameof(ControlsStrings.NameColumnHeader)]</th>
                        <th>@Loc[nameof(Dashboard.Resources.Traces.TracesSpansColumnHeader)]</th>
                        <th style="width: 160px;">@ControlsStringsLoc[nameof(ControlsStrings.DurationColumnHeader)]</th>
                        <th style="width: 90px;">@ControlsStringsLoc[nameof(ControlsStrings.ActionsColumnHeader)]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_totalItemsCount == 0 && _hasLoaded)
                    {
                        <tr>
                            <td colspan="5" class="cell-muted" style="text-align: center; padding: 28px;">
                                @Loc[nameof(Dashboard.Resources.Traces.TracesNoTraces)]
                            </td>
                        </tr>
                    }
                    else
                    {
                        @* Virtualize streams traces from the telemetry repository (up to the configured
                           max). SpacerElement="tr" keeps the virtualization spacers valid inside the table;
                           the scroll container is the surrounding .page__body. *@
                        <Virtualize @ref="_tracesList" ItemsProvider="GetVirtualizedData" ItemSize="46"
                                    OverscanCount="20" SpacerElement="tr" TItem="OtlpTrace" Context="trace">
                            @{
                                var hasError = trace.Spans.Any(s => s.Status == OtlpSpanStatusCode.Error);
                            }
                            <tr class="clickable @(hasError ? "trace-row-error" : "")" @key="trace.TraceId"
                                @onclick="@(() => NavigationManager.NavigateTo(DashboardUrls.TraceDetailUrl(trace.TraceId)))">
                                <td class="cell-muted">
                                    @FormatHelpers.FormatTimeWithOptionalDate(TimeProvider, trace.FirstSpan.StartTime, MillisecondsDisplay.Truncated)
                                </td>
                                <td title="@GetNameTooltip(trace)">
                                    <span class="trace-name-cell">
                                        <span class="trace-name-text" style="border-left-color: @(ColorGenerator.Instance.GetColorVariableByKey(GetResourceName(trace.RootOrFirstSpan.Source)));">
                                            <FluentHighlighter HighlightedText="@(TracesViewModel.FilterText)" Text="@(trace.FullName)" />
                                        </span>
                                        <span class="trace-id">@OtlpHelpers.ToShortenedId(trace.TraceId)</span>
                                        @if (HasGenAISpans(trace))
                                        {
                                            <button type="button" class="icon-btn icon-btn--sm"
                                                    title="@ControlsStringsLoc[nameof(ControlsStrings.GenAIDetailsTitle)]"
                                                    @onclick="() => OnGenAIClickedAsync(trace)"
                                                    @onclick:stopPropagation="true">
                                                <FluentIcon Icon="Icons.Regular.Size16.Sparkle" Color="Color.Accent" />
                                            </button>
                                        }
                                    </span>
                                </td>
                                <td>
                                    <span class="trace-tags">
                                        @foreach (var item in TraceHelpers.GetOrderedResources(trace))
                                        {
                                            <span class="trace-tag" title="@(GetSpansTooltip(item))"
                                                  style="border-left-color: @(ColorGenerator.Instance.GetColorVariableByKey(GetResourceName(item.Resource)));">
                                                @if (item.ErroredSpans > 0)
                                                {
                                                    <FluentIcon Icon="Icons.Filled.Size12.ErrorCircle" Color="Color.Error" Class="trace-tag-icon" />
                                                }
                                                @GetResourceName(item.Resource) (@item.TotalSpans)
                                            </span>
                                        }
                                    </span>
                                </td>
                                <td>
                                    <div class="trace-duration">
                                        <span class="trace-duration-bar">
                                            <span class="trace-duration-fill" style="width: @(GetDurationPercent(trace).ToString("F1", CultureInfo.InvariantCulture))%;"></span>
                                        </span>
                                        <span class="cell-mono trace-duration-text">@DurationFormatter.FormatDuration(trace.Duration, CultureInfo.CurrentCulture)</span>
                                    </div>
                                </td>
                                <td class="no-ellipsis">
                                    <div class="grid-action-container" @onclick:stopPropagation="true">
                                        <TraceActions Trace="@trace" />
                                    </div>
                                </td>
                            </tr>
                        </Virtualize>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
