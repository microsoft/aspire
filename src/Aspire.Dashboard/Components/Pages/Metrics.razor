@page "/metrics"
@page "/metrics/resource/{resourceName}"
@page "/metrics/resource/{resourceName}/meter/{meterName}"
@page "/metrics/resource/{resourceName}/meter/{meterName}/instrument/{instrumentName}"

@using Aspire.Dashboard.Resources
@inject IStringLocalizer<Dashboard.Resources.Metrics> Loc
@inject IStringLocalizer<ControlsStrings> ControlsStringsLoc

<PageTitle>
    @{
        string? additionalText;
        if (PageViewModel.SelectedResource.Id is { ReplicaSetName: { } replicaSetName })
        {
            additionalText = PageViewModel.SelectedInstrument is { } selectedInstrument
                ? $"{replicaSetName} - {selectedInstrument.Name}"
                : replicaSetName;
        }
        else
        {
            additionalText = null;
        }
    }

    <ApplicationName
        AdditionalText="@additionalText"
        ResourceName="@nameof(Dashboard.Resources.Metrics.MetricsPageTitle)"
        Loc="@Loc"/>
</PageTitle>

@{
    var paused = PauseManager.AreMetricsPaused(out _);
    var pauseTitle = paused
        ? ControlsStringsLoc[nameof(ControlsStrings.ResumeButtonTitle)].Value
        : ControlsStringsLoc[nameof(ControlsStrings.PauseButtonTitle)].Value;
    string subtitle;
    if (PageViewModel.SelectedResource.Id is null)
    {
        subtitle = Loc[nameof(Dashboard.Resources.Metrics.MetricsSelectAResource)].Value;
    }
    else if (PageViewModel.Instruments is { Count: > 0 } instruments)
    {
        subtitle = string.Format(System.Globalization.CultureInfo.CurrentCulture, Loc[nameof(Dashboard.Resources.Metrics.MetricsInstrumentsCount)].Value, instruments.Count);
    }
    else
    {
        subtitle = Loc[nameof(Dashboard.Resources.Metrics.MetricsNoMetricsForResource)].Value;
    }
}

<div class="page">
    <div class="page__header">
        <div>
            <div class="page__title">@Loc[nameof(Dashboard.Resources.Metrics.MetricsHeader)]</div>
            <div class="page__subtitle">@subtitle</div>
        </div>
        <div class="page__header-spacer"></div>

        <button type="button"
                class="icon-btn @(paused ? "icon-btn--active" : string.Empty)"
                @onclick="TogglePause"
                title="@pauseTitle"
                aria-label="@pauseTitle">
            <DeckIcon Name="@(paused ? DeckIconName.Play : DeckIconName.Pause)" Size="16" />
        </button>

        <ClearSignalsButton SelectedResource="@PageViewModel.SelectedResource"
                            HandleClearSignal="ClearMetrics" />
    </div>

    <div class="page__toolbar">
        <ResourceSelect Resources="_resourceViewModels"
                        AriaLabel="@ControlsStringsLoc[nameof(ControlsStrings.SelectAResource)]"
                        @bind-SelectedResource="PageViewModel.SelectedResource"
                        @bind-SelectedResource:after="HandleSelectedResourceChangedAsync"
                        CanSelectGrouping="true"
                        LabelClass="toolbar-left" />

        <div class="page__header-spacer"></div>

        <div class="seg" role="group" aria-label="@ControlsStringsLoc[nameof(ControlsStrings.DurationColumnHeader)]">
            @foreach (var duration in _durations)
            {
                var isActive = duration.Id == PageViewModel.SelectedDuration.Id;
                <button type="button"
                        class="seg__btn @(isActive ? "active" : string.Empty)"
                        aria-pressed="@isActive"
                        title="@duration.Name"
                        @onclick="() => HandleDurationClickedAsync(duration)">
                    @GetShortDurationLabel(duration.Id)
                </button>
            }
        </div>
    </div>

    <div class="page__body">
        @if (PageViewModel.Instruments?.Count > 0)
        {
            <div class="metrics-layout">
                <div class="metric-list">
                    <TreeMetricSelector
                        @ref="_treeMetricSelector"
                        PageViewModel="@PageViewModel"
                        HandleSelectedTreeItemChangedAsync="@HandleSelectedTreeItemChangedAsync"/>
                </div>
                <div class="metric-detail">
                    @if (PageViewModel.SelectedResource.Id?.ReplicaSetName != null && PageViewModel is { SelectedMeter: not null, SelectedInstrument: not null })
                    {
                        <ChartContainer
                            ResourceKey="@(PageViewModel.SelectedResource.Id.GetResourceKey())"
                            MeterName="@(PageViewModel.SelectedMeter)"
                            InstrumentName="@(PageViewModel.SelectedInstrument.Name)"
                            Duration="PageViewModel.SelectedDuration.Id"
                            ActiveView="@(PageViewModel.SelectedViewKind ?? Metrics.MetricViewKind.Graph)"
                            OnViewChangedAsync="@OnViewChangedAsync"
                            Resources="@_resources"
                            PauseText="@PauseText" />
                    }
                    else if (PageViewModel.SelectedMeter != null)
                    {
                        <h3 class="meter-name-title">@PageViewModel.SelectedMeter</h3>
                        <div class="table-wrap">
                            <table class="data">
                                <thead>
                                    <tr>
                                        <th style="width: 38%;">@Loc[nameof(Dashboard.Resources.Metrics.MetricsInsturementNameGridNameColumnHeader)]</th>
                                        <th>@Loc[nameof(Dashboard.Resources.Metrics.MetricsInsturementDescriptionGridNameColumnHeader)]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var instrument in PageViewModel.Instruments.Where(i => i.Parent.Name == PageViewModel.SelectedMeter).OrderBy(i => i.Name))
                                    {
                                        <tr @key="instrument">
                                            <td>
                                                <a class="metric-instrument-link cell-mono"
                                                   href="@DashboardUrls.MetricsUrl(resource: PageViewModel.SelectedResource.Name, meter: instrument.Parent.Name, instrument: instrument.Name, duration: DurationMinutes, view: ViewKindName)">
                                                    @instrument.Name
                                                </a>
                                            </td>
                                            <td><span class="cell-muted" title="@instrument.Description">@instrument.Description</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="center-fill cell-muted">@Loc[nameof(Dashboard.Resources.Metrics.MetricsSelectInstrument)]</div>
                    }
                </div>
            </div>
        }
        else
        {
            <EmptyState Title="@(PageViewModel.Instruments is null ? Loc[nameof(Dashboard.Resources.Metrics.MetricsSelectAResource)].Value : Loc[nameof(Dashboard.Resources.Metrics.MetricsNoMetricsForResource)].Value)">
                <IconContent>
                    <DeckIcon Name="DeckIconName.Metrics" Size="26" />
                </IconContent>
            </EmptyState>
        }
    </div>
</div>
