@page "/"
@using Aspire.Dashboard.Components.ResourcesGridColumns
@using Aspire.Dashboard.Resources
@using Aspire.Dashboard.Components.Controls.Grid
@using Humanizer
@inject IStringLocalizer<Dashboard.Resources.Resources> Loc
@inject IStringLocalizer<ControlsStrings> ControlsStringsLoc
@inject IStringLocalizer<Columns> ColumnsLoc

<PageTitle><ApplicationName ResourceName="@nameof(Dashboard.Resources.Resources.ResourcesPageTitle)" Loc="@Loc" /></PageTitle>

@{
    var isGraph = !_hideResourceGraph && PageViewModel.SelectedViewKind == ResourceViewKind.Graph;
    var rows = isGraph ? null : GetVisibleRows();
    var subtitle = _loadingTcs.Task.IsCompletedSuccessfully
        ? $"{_totalItemsCount} {Loc[nameof(Dashboard.Resources.Resources.ResourcesHeader)].Value.ToLowerInvariant()}"
        : ControlsStringsLoc[nameof(ControlsStrings.Loading)].Value;
}

<div class="page">
    <div class="page__header">
        <div>
            <div class="page__title">@Loc[nameof(Dashboard.Resources.Resources.ResourcesHeader)]</div>
            <div class="page__subtitle">@subtitle</div>
        </div>
        <div class="page__header-spacer"></div>

        <SearchBox Value="@PageViewModel.TextFilter" ValueChanged="OnSearchChangedAsync"
                   Placeholder="@ControlsStringsLoc[nameof(ControlsStrings.FilterPlaceholder)]" />

        <button id="resourceFilterButton" type="button"
                class="icon-btn @(NoFiltersSet ? string.Empty : "icon-btn--active")"
                @onclick="() => _isFilterPopupVisible = !_isFilterPopupVisible"
                title="@(NoFiltersSet ? Loc[nameof(Dashboard.Resources.Resources.ResourcesNotFiltered)] : Loc[nameof(Dashboard.Resources.Resources.ResourcesFiltered)])"
                aria-label="@(NoFiltersSet ? Loc[nameof(Dashboard.Resources.Resources.ResourcesNotFiltered)] : Loc[nameof(Dashboard.Resources.Resources.ResourcesFiltered)])">
            <DeckIcon Name="DeckIconName.Filter" Size="17" />
        </button>

        @if (HasViewOptionsMenu())
        {
            <AspireMenuButton ButtonAppearance="Appearance.Stealth"
                              Icon="DeckIconName.Options"
                              Items="@_resourcesMenuItems"
                              Title="@Loc[nameof(Dashboard.Resources.Resources.ResourcesChangeViewOptions)]" />
        }
    </div>

    <div class="page__body" id="resources-page-body-id">
        @if (isGraph)
        {
            <div class="resource-graph-container">
                <svg class="resource-graph"></svg>
                <div class="resource-graph-controls">
                    <button type="button" class="icon-btn graph-zoom-in" title="@Loc[nameof(Dashboard.Resources.Resources.ResourcesGraphZoomInButton)]" aria-label="@Loc[nameof(Dashboard.Resources.Resources.ResourcesGraphZoomInButton)]">+</button>
                    <button type="button" class="icon-btn graph-zoom-out" title="@Loc[nameof(Dashboard.Resources.Resources.ResourcesGraphZoomOutButton)]" aria-label="@Loc[nameof(Dashboard.Resources.Resources.ResourcesGraphZoomOutButton)]">−</button>
                    <button type="button" class="icon-btn graph-reset" title="@Loc[nameof(Dashboard.Resources.Resources.ResourcesGraphResetButton)]" aria-label="@Loc[nameof(Dashboard.Resources.Resources.ResourcesGraphResetButton)]">⟳</button>
                </div>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="data">
                    <thead>
                        <tr>
                            <th style="width: 190px;">@Loc[nameof(Dashboard.Resources.Resources.ResourcesStateColumnHeader)]</th>
                            <th>@ControlsStringsLoc[nameof(ControlsStrings.NameColumnHeader)]</th>
                            @if (_showResourceTypeColumn)
                            {
                                <th style="width: 130px;">@Loc[nameof(Dashboard.Resources.Resources.ResourcesTypeColumnHeader)]</th>
                            }
                            <th>@Loc[nameof(Dashboard.Resources.Resources.ResourcesSourceColumnHeader)]</th>
                            <th>@Loc[nameof(Dashboard.Resources.Resources.ResourcesUrlsColumnHeader)]</th>
                            <th style="width: 130px;">@Loc[nameof(Dashboard.Resources.Resources.ResourcesStartTimeColumnHeader)]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (rows!.Count == 0)
                        {
                            <tr>
                                <td colspan="@(_showResourceTypeColumn ? 6 : 5)" class="cell-muted" style="text-align: center; padding: 28px;">
                                    @(_loadingTcs.Task.IsCompletedSuccessfully ? Loc[nameof(Dashboard.Resources.Resources.ResourcesNoResources)] : ControlsStringsLoc[nameof(ControlsStrings.Loading)])
                                </td>
                            </tr>
                        }
                        else
                        {
                            @* Virtualize keeps the table performant for apps with many resources.
                               SpacerElement="tr" so the virtualization spacers are valid table rows;
                               the scroll container is the .page__body (the .table-wrap clips only). *@
                            <Virtualize Items="rows" Context="vm" ItemSize="46" OverscanCount="20"
                                        SpacerElement="tr" TItem="Aspire.Dashboard.Model.ResourceGridViewModel">
                                @{
                                    var resource = vm.Resource;
                                    var isSelected = string.Equals(resource.Name, PageViewModel.SelectedResource?.Name, StringComparisons.ResourceName);
                                    var source = ResourceSourceViewModel.GetSourceViewModel(resource);
                                    var urls = GetDisplayedUrls(resource);
                                }
                                <tr class="clickable @(isSelected ? "selected" : "")" @key="resource.Name"
                                    @onclick="() => ShowResourceDetailsAsync(resource, buttonId: null)">
                                    <td>
                                        <StateDot Tone="@ResourceStateTone.Get(resource)"
                                                  Text="@ResourceStateViewModel.GetStateViewModel(resource, ColumnsLoc).Text"
                                                  Health="@resource.HealthStatus?.Humanize()" />
                                    </td>
                                    <td>
                                        <span class="cell-name" style="padding-left: @(vm.Depth * 16)px;">
                                            @if (vm.Children.Count > 0)
                                            {
                                                <button type="button" class="row-expand @(vm.IsCollapsed ? string.Empty : "open")"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => OnToggleCollapse(vm)"
                                                        aria-label="@ControlsStringsLoc[nameof(ControlsStrings.ToggleNesting)]">
                                                    <DeckIcon Name="DeckIconName.Chevron" Size="14" />
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="row-expand-spacer"></span>
                                            }
                                            <ResourceNameDisplay Resource="resource" FilterText="@PageViewModel.TextFilter" FormatName="GetResourceName" />
                                        </span>
                                    </td>
                                    @if (_showResourceTypeColumn)
                                    {
                                        <td><span class="cell-muted">@resource.ResourceType</span></td>
                                    }
                                    <td>
                                        @if (source is { } s && !string.IsNullOrEmpty(s.Value))
                                        {
                                            <span class="cell-muted" title="@s.Tooltip">@s.Value</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (urls.Count == 0)
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                        else
                                        {
                                            <span class="url-list">
                                                @foreach (var url in urls)
                                                {
                                                    @if (!string.IsNullOrEmpty(url.Url))
                                                    {
                                                        <a class="url-chip" href="@url.Url" target="_blank" rel="noreferrer noopener"
                                                           title="@url.Url" @onclick:stopPropagation="true">
                                                            <DeckIcon Name="DeckIconName.External" Size="11" />
                                                            @url.Text
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="cell-muted">@url.Text</span>
                                                    }
                                                }
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <span class="cell-muted"><StartTimeColumnDisplay Resource="resource" /></span>
                                    </td>
                                </tr>
                            </Virtualize>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* Context menu for the resource graph (opened from graph nodes via JS interop). *@
<FluentOverlay @bind-Visible="_contextMenuOpen" OnClose="ContextMenuClosed" Transparent="true" FullScreen="true" />
<AspireMenu @bind-Open="_contextMenuOpen" @ref="_contextMenu" Anchor="resources-page-body-id" Anchored="false" Items="_contextMenuItems" />

@* Filter popover (kept as-is for now; opened by the Deck filter button above). *@
<FluentPopover AnchorId="resourceFilterButton"
               @bind-Open="_isFilterPopupVisible"
               AutoFocus="true"
               FixedPlacement="true"
               Class="resources-filter-popup">
    <Body>
        <ResourceFilters ResourceStates="@PageViewModel.ResourceStatesToVisibility"
                         ResourceTypes="@PageViewModel.ResourceTypesToVisibility"
                         ResourceHealthStates="@PageViewModel.ResourceHealthStatusesToVisibility"
                         OnAllFilterVisibilityCheckedChangedAsync="@OnAllFilterVisibilityCheckedChangedAsync"
                         OnResourceFilterVisibilityChangedAsync="@OnResourceFilterVisibilityChangedAsync" />
    </Body>
</FluentPopover>

@* On desktop, resource details open in a Deck-style right-side drawer overlay. *@
@if (ViewportInformation.IsDesktop && PageViewModel.SelectedResource is { } selectedResource)
{
    <ResourceDetailsDrawer Resource="selectedResource"
                           OnClose="@(() => ClearSelectedResourceAsync(causedByUserAction: true))"
                           OnExecuteCommand="@(args => ExecuteResourceCommandAsync(args.Resource, args.Command))" />
}
