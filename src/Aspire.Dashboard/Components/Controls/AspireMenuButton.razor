@namespace Aspire.Dashboard.Components
@using System.Collections.Immutable
@inherits FluentComponentBase

@{
    var additionalButtonAttributes = new Dictionary<string, object>(AdditionalAttributes ?? ImmutableDictionary<string, object>.Empty)
    {
        { "aria-haspopup", "true" },
        { "aria-expanded", _visible ? "true" : "false" },
        { "onkeydown", (KeyboardEventArgs args) => OnKeyDown(args) }
    };

    if (!string.IsNullOrWhiteSpace(Title) &&
        string.IsNullOrWhiteSpace(Text) &&
        !additionalButtonAttributes.ContainsKey("aria-label"))
    {
        additionalButtonAttributes["aria-label"] = Title;
    }

    var tooltipText = Title ?? string.Empty;
    var useFluentTooltip = UseTooltip && !string.IsNullOrWhiteSpace(tooltipText);
}

<FluentButton Id="@MenuButtonId" Title="@(useFluentTooltip || SuppressNativeTooltip ? null : Title)" Appearance="@ButtonAppearance" IconStart="@IconStart" @onclick="ToggleMenu" Disabled="@_disabled" AdditionalAttributes="@additionalButtonAttributes" Class="@ButtonClass">
    @if (string.IsNullOrWhiteSpace(Text))
    {
        <FluentIcon Value="@_icon" Color="@IconColor" CustomColor="@IconCustomColor" />
    }
    else
    {
        @Text

        @if (!HideIcon)
        {
            <FluentIcon Value="@_icon" Color="@IconColor" CustomColor="@IconCustomColor" Slot="end" />
        }
    }
</FluentButton>

@if (useFluentTooltip)
{
    <AspireTooltip Anchor="@MenuButtonId" Text="@tooltipText" />
}

<AspireMenu Anchor="@MenuButtonId" @bind-Open="@_visible" Items="_items" RestoreFocusOnItemClick="@RestoreFocusOnItemClick" />
