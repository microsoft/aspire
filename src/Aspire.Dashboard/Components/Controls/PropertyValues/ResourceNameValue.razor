@* Do this to trim significant whitespace so there isn't a space added between icon and text *@
@{
    <ResourceIcon Resource="Resource"
                  Size="16"
                  Class="resource-icon"
                  Style="@($"color: {ColorGenerator.Instance.GetColorVariableByKey(FormatName(Resource))};")" />
}
<Highlighter HighlightedText="@HighlightText" Text="@Value" />
