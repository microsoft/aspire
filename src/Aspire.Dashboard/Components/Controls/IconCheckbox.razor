@namespace Aspire.Dashboard.Components

@* The checkbox semantics live on this focusable span (role=checkbox) so the icon glyph
   fully controls the rendered appearance; Space-key handling is wired up in JS. *@
<span @ref="_element"
      class="icon-checkbox @CssClass"
      tabindex="@TabIndex"
      role="checkbox"
      aria-checked="@AriaChecked"
      aria-disabled="@AriaDisabled"
      title="@AccessibleLabel"
      aria-label="@AccessibleLabel"
      @onclick="HandleClickAsync"
      @onclick:stopPropagation="@StopPropagation">
    <DeckIcon Name="@CurrentIcon" Size="20" />
</span>
