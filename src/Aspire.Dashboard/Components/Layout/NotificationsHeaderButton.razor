@using Aspire.Dashboard.Resources

@if (UnreadCount > 0)
{
    <FluentButton Class="header-button"
                  Appearance="ButtonAppearance.Transparent" OnClick="@HandleClick"
                  Title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <FluentCounterBadge Count="@UnreadCount"
                            OverflowCount="9"
                            ShowOverflow="true"
                            Appearance="BadgeAppearance.Filled"
                            Color="BadgeColor.Danger"
                            Style="border: 0;">
            <ChildContent>
                <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Default" Style="vertical-align: bottom;" />
            </ChildContent>
        </FluentCounterBadge>
    </FluentButton>
}
else
{
    <FluentButton Class="header-button"
                  Appearance="ButtonAppearance.Transparent" OnClick="@HandleClick"
                  Title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Default" />
    </FluentButton>
}
