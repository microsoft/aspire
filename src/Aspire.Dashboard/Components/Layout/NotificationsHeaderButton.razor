@using Aspire.Dashboard.Resources

@if (UnreadCount > 0)
{
    <button type="button" class="icon-btn header-button"
            @onclick="@HandleClick"
            title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <FluentCounterBadge Count="@UnreadCount"
                            Max="9"
                            ShowOverflow="true"
                            BackgroundColor="@Color.FillInverse"
                            Color="Color.Fill"
                            Appearance="Appearance.Accent"
                            Style="border: 0;">
            <ChildContent>
                <DeckIcon Name="DeckIconName.Bell" Size="24" />
            </ChildContent>
        </FluentCounterBadge>
    </button>
}
else
{
    <button type="button" class="icon-btn header-button"
            @onclick="@HandleClick"
            title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <DeckIcon Name="DeckIconName.Bell" Size="24" />
    </button>
}
