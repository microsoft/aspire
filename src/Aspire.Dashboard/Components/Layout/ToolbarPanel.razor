

<FluentDialogBody>
    <FluentStack Orientation="@Orientation.Vertical">
        @Content.ToolbarSection
    </FluentStack>

    <FluentButton Class="mobile-absolute-toolbar mobile-toolbar"
                  Appearance="@ButtonAppearance.Primary"
                  Disabled="true">
        @Content.MobileToolbarButtonText
    </FluentButton>
</FluentDialogBody>

@code {
    [Parameter]
    public required AspirePageContentLayout.MobileToolbar Content { get; set; }
}
