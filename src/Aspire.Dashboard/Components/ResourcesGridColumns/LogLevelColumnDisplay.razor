@namespace Aspire.Dashboard.Components

@using Aspire.Dashboard.Resources
@using Microsoft.Extensions.Logging

@if (LogEntry.IsError)
{
    <DeckIcon Name="DeckIconName.ErrorCircle" Size="16" Class="severity-icon icon-error" />
}
else if (LogEntry.IsWarning)
{
    <DeckIcon Name="DeckIconName.Warning" Size="16" Class="severity-icon icon-warning" />
}

@LogEntry.Severity

@code {
    [Parameter, EditorRequired]
    public required OtlpLogEntry LogEntry { get; set; }
}
