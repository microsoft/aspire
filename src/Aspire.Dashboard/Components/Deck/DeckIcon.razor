@*
    Minimal inline icon set for the Deck-style UI, ported from
    src/Aspire.Deck/ui/src/components/Icons.tsx. Stroke-based, currentColor, 24x24 viewBox,
    so we avoid shipping an icon font/library. Keep names and paths in sync with Deck.
*@
<svg width="@Size" height="@Size" viewBox="0 0 24 24" fill="none" stroke="currentColor"
     stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
     class="@Class" aria-hidden="true">
    @switch (Resolve(Name))
    {
        case DeckIconName.Resources:
            <rect x="3" y="3" width="7" height="7" rx="1.5" />
            <rect x="14" y="3" width="7" height="7" rx="1.5" />
            <rect x="3" y="14" width="7" height="7" rx="1.5" />
            <rect x="14" y="14" width="7" height="7" rx="1.5" />
            break;
        case DeckIconName.Parameters:
            <line x1="4" y1="8" x2="20" y2="8" />
            <line x1="4" y1="16" x2="20" y2="16" />
            <circle cx="9" cy="8" r="2.4" />
            <circle cx="15" cy="16" r="2.4" />
            break;
        case DeckIconName.Console:
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <path d="m7 9 3 3-3 3" />
            <path d="M13 15h4" />
            break;
        case DeckIconName.Logs:
            <path d="M4 6h16" />
            <path d="M4 12h16" />
            <path d="M4 18h10" />
            break;
        case DeckIconName.Traces:
            <path d="M4 5h16" />
            <path d="M4 5v14" />
            <path d="M8 9h9" />
            <path d="M8 13h6" />
            <path d="M8 17h11" />
