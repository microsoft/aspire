@*
    Masks a sensitive value until the user reveals it, ported from the SecretValue helper in
    src/Aspire.Deck/ui/src/components/DetailsDrawer.tsx. Uses the Deck .secret / .reveal-btn styles.
*@
<span class="secret">@(_revealed ? Value : new string('•', Math.Min(Value?.Length ?? 0, 24)))</span>
<button class="reveal-btn" type="button" @onclick="Toggle"
        title="@(_revealed ? Hide : Reveal)" aria-label="@(_revealed ? Hide : Reveal)">
    <DeckIcon Name="@(_revealed ? DeckIconName.EyeOff : DeckIconName.Eye)" Size="15" />
</button>

@code {
    private bool _revealed;

    /// <summary>The sensitive value to mask/reveal.</summary>
    [Parameter, EditorRequired]
    public string? Value { get; set; }

    /// <summary>Accessible label for the reveal action.</summary>
    [Parameter]
    public string Reveal { get; set; } = "Reveal value";

    /// <summary>Accessible label for the hide action.</summary>
    [Parameter]
    public string Hide { get; set; } = "Hide value";

    private void Toggle() => _revealed = !_revealed;
}
