@using Aspire.Dashboard.Resources
@using Aspire.Dashboard.Utils
@inject IStringLocalizer<Dialogs> Loc

<FluentDialogBody>
    <div class="notifications-container">
        @if (_notifications.Count == 0)
        {
            <div class="notification-center-empty">
                <DeckIcon Name="DeckIconName.Bell" Size="24" />
                <p>@Loc[nameof(Dialogs.NotificationCenterEmpty)]</p>
            </div>
        }
        else
        {
            <div class="notifications-dismiss">
                <button type="button" class="btn btn--ghost" @onclick="@DismissAll">
                    @Loc[nameof(Dialogs.NotificationCenterDismissAll)]
                </button>
            </div>
            <div class="notifications-scroll">
                @foreach (var notification in _notifications)
                {
                    <NotificationEntryComponent Entry="@notification.Entry" OnDismiss="@(() => Dismiss(notification.Id))" />
                }
            </div>
        }
    </div>
</FluentDialogBody>
