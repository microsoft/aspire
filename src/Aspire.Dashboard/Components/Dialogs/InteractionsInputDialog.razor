@using Aspire.Dashboard.Components.Controls.Chart
@using Aspire.Dashboard.Model.Interaction
@using Aspire.Dashboard.Resources
@using Aspire.Dashboard.Components.Controls.Grid
@using Aspire.DashboardService.Proto.V1
@using Dialogs = Aspire.Dashboard.Resources.Dialogs
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@implements IDialogContentComponent<InteractionsInputsDialogViewModel>

<FluentDialogHeader ShowDismiss="@Dialog.Instance.Parameters.ShowDismiss">
    <div class="deck-stack" style="align-items: center;">
        <FluentLabel Typo="Typography.PaneHeader">
            @Dialog.Instance.Parameters.Title
        </FluentLabel>
    </div>
</FluentDialogHeader>

<FluentDialogBody Class="interaction-input-dialog">
    @if (!string.IsNullOrEmpty(Content.Message))
    {
        <div class="interaction-message">
            @((MarkupString)Content.Message)
        </div>
    }

    <EditForm EditContext="@_editContext" OnValidSubmit="@SubmitAsync">
        <div class="deck-stack deck-stack--vertical" style="row-gap: 12px;">
            @foreach (var vm in _inputDialogInputViewModels)
            {
                var localItem = vm;
                <div class="interaction-input input-container">
                    @switch (vm.Input.InputType)
                    {
                        case InputType.Text:
                            <InteractionInputField ForId="@_fieldIds[localItem]"
                                                   InputViewModel="@localItem"
                                                   MarkdownProcessor="@_markdownProcessor"
                                                   Context="input">
                                @*
                                * Binding on oninput ensures the value is set to the server token with every key press in the textbox.
                                *@
                                <input id="@_fieldIds[input.ViewModel]"
                                       type="text"
                                       class="input"
                                       value="@input.ViewModel.Value"
                                       @oninput="@(e => OnStringValueChanged(input.ViewModel, e))"
                                       placeholder="@input.ViewModel.Input.Placeholder"
                                       required="@input.ViewModel.Input.Required"
                                       autocomplete="off"
                                       disabled="@input.ViewModel.InputDisabled"
                                       aria-describedby="@input.DescriptionId"
                                       maxlength="@InteractionHelpers.GetMaxLength(input.ViewModel.Input.MaxLength)" />
                            </InteractionInputField>
                            break;
                        case InputType.SecretText:
                            <InteractionInputField ForId="@_fieldIds[localItem]"
                                                   InputViewModel="@localItem"
                                                   MarkdownProcessor="@_markdownProcessor"
                                                   Context="input">
                                @*
                                * AutoComplete value of one-time-code on password input prevents the browser asking to save the value.
                                * Binding on oninput ensures the value is set to the server token with every key press in the textbox.
                                *@
                                <div class="input-with-button">
                                    <input id="@_fieldIds[input.ViewModel]"
                                           type="password"
                                           class="input"
                                           value="@input.ViewModel.Value"
                                           @oninput="@(e => OnStringValueChanged(input.ViewModel, e))"
                                           placeholder="@input.ViewModel.Input.Placeholder"
                                           required="@input.ViewModel.Input.Required"
                                           autocomplete="one-time-code"
                                           disabled="@input.ViewModel.InputDisabled"
                                           aria-describedby="@input.DescriptionId"
                                           maxlength="@InteractionHelpers.GetMaxLength(input.ViewModel.Input.MaxLength)" />
                                    <button type="button"
                                            class="icon-btn icon-btn--sm secret-text-toggle-button"
                                            title="@(input.ViewModel.IsSecretTextVisible ? ControlsStringsLoc[nameof(ControlsStrings.GridValueMaskHideValue)] : ControlsStringsLoc[nameof(ControlsStrings.GridValueMaskShowValue)])"
                                            @onclick="@(() => ToggleSecretTextVisibilityAsync(input.ViewModel))">
                                        <DeckIcon Name="GetSecretTextIcon(input.ViewModel)" Size="16" />
                                    </button>
                                </div>
                            </InteractionInputField>
                            break;
                        case InputType.Choice:
                            <InteractionInputField ForId="@_fieldIds[localItem]"
                                                   InputViewModel="@localItem"
                                                   MarkdownProcessor="@_markdownProcessor"
                                                   Context="input">
                                @*
                                * Need to wrap the select in a div to display a progress bar next to it.
                                * Because of this we have to use a separate label control rather than have the select be responsible for displaying it.
                                *@
                                @if (!localItem.Input.AllowCustomChoice)
                                {
                                    <select id="@_fieldIds[input.ViewModel]"
                                            @key="input.ViewModel.InputKey"
                                            class="select"
                                            @onchange="@(e => OnStringValueChanged(input.ViewModel, e))"
                                            disabled="@input.ViewModel.InputDisabled"
                                            aria-describedby="@input.DescriptionId">
                                        @if (!string.IsNullOrEmpty(input.ViewModel.Input.Placeholder))
                                        {
                                            <option value="" disabled hidden selected="@string.IsNullOrEmpty(input.ViewModel.Value)">@input.ViewModel.Input.Placeholder</option>
                                        }
                                        @foreach (var option in input.ViewModel.SelectOptions)
                                        {
                                            <option value="@option.Id"
                                                    selected="@(option.Id == input.ViewModel.Value)"
                                                    title="@DashboardUIHelpers.ResolveTooltip(option.Name)">@option.Name</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <FluentCombobox @key="input.ViewModel.InputKey"
                                                    TOption="SelectViewModel<string>"
                                                    Id="@_fieldIds[input.ViewModel]"
                                                    @bind-Value="input.ViewModel.Value"
                                                    Placeholder="@input.ViewModel.Input.Placeholder"
                                                    Required="input.ViewModel.Input.Required"
                                                    Items="@input.ViewModel.FilteredOptions()"
                                                    OptionValue="@(vm => vm.Id)"
                                                    OptionText="@(vm => vm.Name)"
                                                    OptionTitle="@(vm => DashboardUIHelpers.ResolveTooltip(vm.Name))"
                                                    Height="250px"
                                                    Position="SelectPosition.Below"
                                                    Disabled="input.ViewModel.InputDisabled"
                                                    Immediate="true"
                                                    ImmediateDelay="@FluentUIExtensions.InputDelay"
                                                    aria-describedby="@input.DescriptionId">
                                        <OptionTemplate Context="optionContext">
                                            <Highlighter Text="@optionContext.Name" HighlightedText="@input.ViewModel.Value" />
                                        </OptionTemplate>
                                    </FluentCombobox>
                                }
                            </InteractionInputField>
                            break;
                        case InputType.Boolean:
                            <InteractionInputField ForId="@_fieldIds[localItem]"
                                                   InputViewModel="@localItem"
                                                   MarkdownProcessor="@_markdownProcessor"
                                                   Context="input">
                                <Checkbox Checked="input.ViewModel.IsChecked"
                                          CheckedChanged="@(value => OnCheckedChanged(input.ViewModel, value))"
                                          Label="@input.ViewModel.Input.Label"
                                          AriaLabel="@input.ViewModel.Input.Label"
                                          Disabled="input.ViewModel.InputDisabled" />
                            </InteractionInputField>
                            break;
                        case InputType.Number:
                            <InteractionInputField ForId="@_fieldIds[localItem]"
                                                   InputViewModel="@localItem"
                                                   MarkdownProcessor="@_markdownProcessor"
                                                   Context="input">
                                <input id="@_fieldIds[input.ViewModel]"
                                       type="number"
                                       class="input"
                                       value="@input.ViewModel.NumberValue"
                                       @oninput="@(e => OnNumberValueChanged(input.ViewModel, e))"
                                       placeholder="@input.ViewModel.Input.Placeholder"
                                       aria-label="@input.ViewModel.Input.Description"
                                       required="@input.ViewModel.Input.Required"
                                       disabled="@input.ViewModel.InputDisabled"
                                       aria-describedby="@input.DescriptionId" />
                            </InteractionInputField>
                            break;
                        default:
                            @* Ignore unexpected InputTypes *@
                            break;
                    }
                </div>
            }
        </div>

        @* Hidden submit is so the form is submitted when the user presses enter. *@
        <button type="submit" style="display:none"></button>
    </EditForm>
</FluentDialogBody>

<FluentDialogFooter>
    <button type="button" class="btn btn--primary" @onclick="@SubmitAsync">
        @Dialog.Instance.Parameters.PrimaryAction
    </button>
    @if (!string.IsNullOrEmpty(Dialog.Instance.Parameters.SecondaryAction))
    {
        <button type="button" class="btn" @onclick="@CancelAsync">
            @Dialog.Instance.Parameters.SecondaryAction
        </button>
    }
</FluentDialogFooter>
