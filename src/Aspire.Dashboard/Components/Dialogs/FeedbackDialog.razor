@using Aspire.Dashboard.Resources
@using LayoutResources = Aspire.Dashboard.Resources.Layout
@implements IDialogContentComponent<FeedbackDialogViewModel>

<FluentDialogBody Class="feedback-dialog-body">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <div class="feedback-input input-container">
            <FluentTextField Id="@TitleInputId"
                             Label="@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackIssueTitleLabel)]"
                             @bind-Value="_title"
                             Immediate="true"
                             Required="true"
                             Autofocus="true"
                             AutoComplete="off" />
        </div>

        <div class="feedback-input input-container">
            <div class="feedback-textarea-label">
                <FluentInputLabel ForId="@MainTextInputId" Label="@MainTextLabel" AriaLabel="@MainTextLabel" Required="true" />
            </div>
            <div class="feedback-input-line">
                <FluentTextArea Id="@MainTextInputId"
                                @bind-Value="_mainText"
                                Immediate="true"
                                Required="true"
                                Rows="6"
                                Resize="TextAreaResize.Vertical" />
            </div>
        </div>

        <FluentAccordion Class="feedback-details-accordion">
            <FluentAccordionItem Heading="@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackDetailsHeading)]" Expanded="false">
                @if (_isCapturingBugContext)
                {
                    @* While `aspire doctor` output is being gathered the Open issue button is disabled
                       (see CanOpenIssue). The accordion is collapsed by default, so surface the spinner
                       in the header so the user can see why submission is blocked without expanding it. *@
                    <div slot="end" class="feedback-details-loading">
                        <FluentProgressRing Width="16px" />
                        <span>@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackDoctorLoadingMessage)]</span>
                    </div>
                }
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                    @if (_showAspireDoctorOutput)
                    {
                        <div class="feedback-input input-container">
                            <div class="feedback-textarea-label">
                                <FluentInputLabel ForId="@DoctorOutputInputId" Label="@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackAspireDoctorOutputLabel)]" AriaLabel="@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackAspireDoctorOutputLabel)]" />
                            </div>
                            <div class="feedback-input-line">
                                <FluentTextArea Id="@DoctorOutputInputId"
                                                Class="feedback-dialog-monospace"
                                                @bind-Value="_aspireDoctorOutput"
                                                Immediate="true"
                                                ReadOnly="@_isCapturingBugContext"
                                                Rows="8"
                                                Resize="TextAreaResize.Vertical"
                                                Spellcheck="false"
                                                aria-busy="@(_isCapturingBugContext ? "true" : "false")" />
                                @if (_isCapturingBugContext)
                                {
                                    <FluentProgressRing Width="20px" Class="feedback-input-progress" Title="@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackDoctorLoadingMessage)]" />
                                }
                            </div>
                        </div>
                    }

                    <div class="feedback-input input-container">
                        <div class="feedback-textarea-label">
                            <FluentInputLabel ForId="@AdditionalContextInputId" Label="@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackAdditionalContextLabel)]" AriaLabel="@Loc[nameof(LayoutResources.MainLayoutProvideFeedbackAdditionalContextLabel)]" />
                        </div>
                        <div class="feedback-input-line">
                            <FluentTextArea Id="@AdditionalContextInputId"
                                            Class="feedback-dialog-monospace"
                                            @bind-Value="_additionalContext"
                                            Immediate="true"
                                            Rows="5"
                                            Resize="TextAreaResize.Vertical"
                                            Spellcheck="false" />
                        </div>
                    </div>
                </FluentStack>
            </FluentAccordionItem>
        </FluentAccordion>
    </FluentStack>
</FluentDialogBody>

<FluentDialogFooter>
    <div class="feedback-dialog-footer-content">
        <span class="feedback-dialog-public-message" role="note">
            @{
                // The localized message embeds the repo link via a {0} placeholder so the
                // "microsoft/aspire" anchor renders inline; split around it to keep the surrounding
                // text localizable while the repo identifier and URL stay fixed. Translations that
                // predate the placeholder simply render their full text followed by the link.
                var publicMessageParts = Loc[nameof(LayoutResources.MainLayoutProvideFeedbackPublicIssueMessage)].Value.Split("{0}", 2, StringSplitOptions.None);
            }
            @publicMessageParts[0]<FluentAnchor Href="https://github.com/microsoft/aspire" Target="_blank" Rel="noreferrer noopener" Appearance="Appearance.Hypertext">microsoft/aspire</FluentAnchor>@(publicMessageParts.Length > 1 ? publicMessageParts[1] : string.Empty)
        </span>
        <FluentButton Id="@OpenIssueButtonId"
                      Appearance="Appearance.Accent"
                      Disabled="@(!CanOpenIssue)"
                      OnClick="@OpenIssueAsync"
                      data-openbutton="@(CanOpenIssue ? "true" : null)"
                      data-url="@(CanOpenIssue ? IssueUrl : null)"
                      data-target="_blank">
            @Loc[nameof(LayoutResources.MainLayoutProvideFeedbackOpenIssueButton)]
        </FluentButton>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@CancelAsync">
            @DialogsLoc[nameof(Dialogs.FilterDialogCancelButtonText)]
        </FluentButton>
    </div>
</FluentDialogFooter>
