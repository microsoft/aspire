@using Aspire.Dashboard.Extensions
@using Aspire.Dashboard.Model.GenAI
@using Aspire.Dashboard.Resources

@implements IDialogContentComponent<GenAIVisualizerDialogViewModel>

<FluentDialogHeader ShowDismiss="true">
    <div class="dialog-title-grid">
        <FluentIcon Value="@(new Icons.Regular.Size24.Sparkle())" Style="grid-area: dialog-icon; align-self: center;" />
        <FluentLabel Typo="Typography.PaneHeader" Class="col-long-content" Style="grid-area: dialog-title;">
            @Content.Title
            <span class="trace-id">@OtlpHelpers.ToShortenedId(Content.Span.SpanId)</span>
        </FluentLabel>

        @if (_contextSpans.Count > 1)
        {
            <div Style="grid-area: dialog-format;">
                <button type="button" class="btn btn--ghost"
                        disabled="@NoPreviousGenAISpan"
                        @onclick="OnPreviousGenAISpan">
                    <DeckIcon Name="DeckIconName.ArrowUp" Size="16" />
                    @Loc[nameof(Dialogs.GenAIPreviousButtonText)]
                </button>
                <button type="button" class="btn btn--ghost"
                        disabled="@NoNextGenAISpan"
                        @onclick="OnNextGenAISpan">
                    <DeckIcon Name="DeckIconName.ArrowDown" Size="16" />
                    @Loc[nameof(Dialogs.GenAINextButtonText)]
                </button>
            </div>
        }
    </div>
</FluentDialogHeader>

<FluentDialogBody>
    <div class="genai-visualizer-container">
        <FluentSplitter BarHandle="true"
                        Style="height:100%"
                        Panel1Size="3fr"
                        Panel2Size="7fr"
                        BarSize="10">
            <Panel1>
                <div class="span-messages-sidebar">
                    <TreeGenAISelector PageViewModel="@Content"
                                       SelectedItem="@SelectedItem"
                                       HandleSelectedTreeItemChangedAsync="@HandleSelectedTreeItemChangedAsync" />
                </div>
            </Panel1>
            <Panel2>
                <div class="span-messages-container">
                    @if (SelectedItem is { } selectedItem)
                    {
                        var selectedView = selectedItem.Type == GenAIItemType.Error
                            ? ItemViewKind.Raw
                            : MessageActiveView;

                        <div>
                            <div class="message-header">
                                <GenAIItemTitle Item="@selectedItem" ResourceName="@selectedItem.ResourceName" />
                                <button type="button" class="icon-btn back-button" @onclick="@GoBackAsync">
                                    <DeckIcon Name="DeckIconName.Back" Size="16" />
                                </button>
                            </div>
                            @*
                                Tab content isn't nested inside DeckTab elements. The tab control is just used to display the tabs.
                                Content is located in manually created divs so they can be placed in their own CSS grid row.
                            *@
                            @if (selectedItem.Type != GenAIItemType.Error)
                            {
                                <DeckTabs ActiveTabId="@($"tab-message-{selectedView}")" OnTabChange="@OnMessageTabChange">
                                    <DeckTab LabelClass="tab-label"
                                             Id="@($"tab-message-{ItemViewKind.Preview}")"
                                             Label="@Loc[nameof(Dialogs.GenAIPreviewTabText)]"
                                             Icon="DeckIconName.Eye">
                                    </DeckTab>
                                    <DeckTab LabelClass="tab-label"
                                             Id="@($"tab-message-{ItemViewKind.Raw}")"
                                             Label="@Loc[nameof(Dialogs.GenAIRawTabText)]"
                                             Icon="DeckIconName.Braces">
                                    </DeckTab>
                                </DeckTabs>
                            }
                            else
                            {
                                <DeckTabs ActiveTabId="@($"tab-message-{ItemViewKind.Raw}")">
                                    <DeckTab LabelClass="tab-label"
                                             Id="@($"tab-message-{ItemViewKind.Raw}")"
                                             Label="@Loc[nameof(Dialogs.GenAIRawTabText)]"
                                             Icon="DeckIconName.Braces">
                                    </DeckTab>
                                </DeckTabs>
                            }
                        </div>
                        @if (selectedView == ItemViewKind.Preview)
                        {
                            <div class="tab-container">
                                @foreach (var itemPart in selectedItem.ItemParts)
                                {
                                    if (itemPart.ErrorMessage is not null)
                                    {
                                        <span class="error-message-text">@itemPart.ErrorMessage</span>
                                    }

                                    if (TryGetDataPart(itemPart, MimeTypeHelpers.SupportedImageTypes, out var imageData))
                                    {
                                        <img src="@imageData.Url" />
                                    }
                                    else if (TryGetDataPart(itemPart, MimeTypeHelpers.SupportedAudioTypes, out var audioData))
                                    {
                                        <audio controls>
                                            <source src="@audioData.Url" type="@audioData.MimeType">
                                            <!-- If file isn't supported then fallback to download link -->
                                            <a href="@audioData.Url" download="@audioData.FileName">@audioData.FileName</a>
                                        </audio>
                                    }
                                    else if (TryGetDataPart(itemPart, MimeTypeHelpers.SupportedVideoTypes, out var videoData))
                                    {
                                        <video controls>
                                            <source src="@videoData.Url" type="@videoData.MimeType">
                                            <!-- If file isn't supported then fallback to download link -->
                                            <a href="@videoData.Url" download="@videoData.FileName">@videoData.FileName</a>
                                        </video>
                                    }
                                    else if (TryGetDataPart(itemPart, matchingMimeTypes: null, out var otherData))
                                    {
                                        <a href="@otherData.Url" download="@otherData.FileName">@otherData.FileName</a>
                                    }
                                    else if (itemPart.AdditionalProperties is { } additionalProperties && additionalProperties.Count > 0)
                                    {
                                        <div class="property-grid-container">
                                            <Accordion>
                                                <AccordionItem Heading="@(itemPart.MessagePart?.Type ?? "unknown")" Expanded="true" Count="@additionalProperties.Count">
                                                    <PropertyGrid TItem="GenAIPartPropertyViewModel"
                                                                  Items="additionalProperties.AsQueryable()"
                                                                  IsNameSortable="false"
                                                                  IsValueSortable="false"
                                                                  GridTemplateColumns="1fr 2fr" />
                                                </AccordionItem>
                                            </Accordion>
                                        </div>
                                    }
                                    else if (itemPart.ErrorMessage == itemPart.TextVisualizerViewModel.Text)
                                    {
                                        // Don't display text if it is the same as error message.
                                    }
                                    else
                                    {
                                        if (itemPart.TextVisualizerViewModel.FormatKind is DashboardUIHelpers.PlaintextFormat)
                                        {
                                            @itemPart.TextVisualizerViewModel.FormattedText
                                        }
                                        else if (itemPart.TextVisualizerViewModel.FormatKind is DashboardUIHelpers.MarkdownFormat)
                                        {
                                            <MarkdownRenderer MarkdownProcessor="@_markdownProcess" Markdown="@itemPart.TextVisualizerViewModel.FormattedText" />
                                        }
                                        else
                                        {
                                            <TextVisualizer ViewModel="@itemPart.TextVisualizerViewModel" HideLineNumbers="true" Virtualize="false" />
                                        }

                                        if (itemPart.MessagePart is ToolCallRequestPart toolCallPart && !string.IsNullOrEmpty(toolCallPart.Name))
                                        {
                                            if (Content.ToolDefinitions.FirstOrDefault(d => d.ToolDefinition.Name == toolCallPart.Name) is { } toolVM)
                                            {
                                                <div class="tool-button-container">
                                                    <button type="button" class="btn" @onclick="@(() => ViewToolDefinitionAsync(toolVM))">
                                                        <DeckIcon Name="DeckIconName.Toolbox" Size="16" />
                                                        @Loc[nameof(Dialogs.GenAIToolDefinitionButtonText)]
                                                    </button>
                                                </div>
                                            }
                                        }
                                        else if (itemPart.MessagePart is ServerToolCallPart serverToolCallPart && !string.IsNullOrEmpty(serverToolCallPart.Name))
                                        {
                                            if (Content.ToolDefinitions.FirstOrDefault(d => d.ToolDefinition.Name == serverToolCallPart.Name) is { } toolVM)
                                            {
                                                <div class="tool-button-container">
                                                    <button type="button" class="btn" @onclick="@(() => ViewToolDefinitionAsync(toolVM))">
                                                        <DeckIcon Name="DeckIconName.Toolbox" Size="16" />
                                                        @Loc[nameof(Dialogs.GenAIToolDefinitionButtonText)]
                                                    </button>
                                                </div>
                                            }
                                        }
                                        else if (itemPart.MessagePart is ToolCallResponsePart toolCallResponsePart && !string.IsNullOrEmpty(toolCallResponsePart.Id))
                                        {
                                            if (TryGetToolCall(toolCallResponsePart.Id, out var itemVM, out var toolCallRequestPart))
                                            {
                                                <div class="tool-button-container">
                                                    <button type="button" class="btn" @onclick="@(() => OnViewItem(itemVM))">
                                                        <DeckIcon Name="DeckIconName.Braces" Size="16" />
                                                        @Loc[nameof(Dialogs.GenAIToolCallButtonText)]
                                                    </button>

                                                    @if (Content.ToolDefinitions.FirstOrDefault(d => d.ToolDefinition.Name == toolCallRequestPart.Name) is { } toolVM)
                                                    {
                                                        <button type="button" class="btn" @onclick="@(() => ViewToolDefinitionAsync(toolVM))">
                                                            <DeckIcon Name="DeckIconName.Toolbox" Size="16" />
                                                            @Loc[nameof(Dialogs.GenAIToolDefinitionButtonText)]
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        }
                                    }
                                }
                            </div>
                        }
                        @if (selectedView == ItemViewKind.Raw)
                        {
                            <div class="tab-container">
                                @foreach (var itemPart in selectedItem.ItemParts)
                                {
                                    <TextVisualizer ViewModel="@itemPart.TextVisualizerViewModel" DisplayUnformatted="true" Virtualize="false" />
                                }
                            </div>
                        }
                        <DeckClipboardCopyButton Id="@_copyButtonId"
                                                 Class="btn message-copy-button"
                                                 AdditionalAttributes="@FluentUIExtensions.GetClipboardCopyAdditionalAttributes(string.Join(Environment.NewLine + Environment.NewLine, selectedItem.ItemParts.Select(p => p.TextVisualizerViewModel?.FormattedText ?? string.Empty)), ControlsStringsLoc[nameof(ControlsStrings.GridValueCopyToClipboard)], ControlsStringsLoc[nameof(ControlsStrings.GridValueCopied)])">
                            @ControlsStringsLoc[nameof(ControlsStrings.GridValueCopyToClipboard)]
                        </DeckClipboardCopyButton>
                    }
                    else
                    {
                        <div>
                            <div class="message-header">
                                <span class="llm-badge">@Loc[nameof(Dialogs.GenAILLMBadgeText)]</span>
                                <div class="message-header-title">
                                    <span>@Content.Span.Name</span>
                                    <span class="message-header-date">@FormatHelpers.FormatTimeWithOptionalDate(TimeProvider, Content.Span.StartTime, MillisecondsDisplay.Truncated)</span>
                                </div>
                                @{
                                    var tokenTotal = Content.InputTokens + Content.OutputTokens;
                                    var tokenText = tokenTotal == null ? Loc[nameof(Dialogs.GenAINAText)] : tokenTotal.Value.ToString(CultureInfo.CurrentCulture);
                                    string tokenTooltip;
                                    if (tokenTotal == null)
                                    {
                                        tokenTooltip = Loc[nameof(Dialogs.GenAINAText)];
                                    }
                                    else
                                    {
                                        tokenTooltip = string.Format(CultureInfo.CurrentCulture, Loc[nameof(Dialogs.GenAIInputTokensText)], Content.InputTokens ?? 0) +
                                            Environment.NewLine +
                                            string.Format(CultureInfo.CurrentCulture, Loc[nameof(Dialogs.GenAIOutputTokensText)], Content.OutputTokens ?? 0);
                                    }
                                }
                                <div class="message-header-details">
                                    <span>@Loc[nameof(Dialogs.GenAIDurationLabel)] <strong>@DurationFormatter.FormatDuration(Content.Span.Duration, CultureInfo.CurrentCulture)</strong></span>
                                    <span title="@tokenTooltip">@Loc[nameof(Dialogs.GenAITokensLabel)] <strong>@tokenText</strong></span>
                                </div>
                            </div>
                            @*
                                Tab content isn't nested inside DeckTab elements. The tab control is just used to display the tabs.
                                Content is located in manually created divs so they can be placed in their own CSS grid row.
                            *@
                            <DeckTabs ActiveTabId="@($"tab-overview-{OverviewActiveView}")" OnTabChange="@OnOverviewTabChange">
                                <DeckTab LabelClass="tab-label"
                                         Id="@($"tab-overview-{OverviewViewKind.InputOutput}")"
                                         Label="@Loc[nameof(Dialogs.GenAIInputOutputTabText)]"
                                         Icon="DeckIconName.Mail">
                                </DeckTab>
                                @if (Content.ToolDefinitions.Count > 0)
                                {
                                    <DeckTab LabelClass="tab-label"
                                             Id="@($"tab-overview-{OverviewViewKind.Tools}")"
                                             Icon="DeckIconName.Toolbox">
                                        <Header>
                                            <span class="tab-text">@Loc[nameof(Dialogs.GenAIToolsTabText)]</span>
                                            <Badge>@Content.ToolDefinitions.Count</Badge>
                                        </Header>
                                    </DeckTab>
                                }
                                @if (Content.Evaluations.Count > 0)
                                {
                                    <DeckTab LabelClass="tab-label"
                                             Id="@($"tab-overview-{OverviewViewKind.Evaluations}")"
                                             Icon="DeckIconName.Gauge">
                                        <Header>
                                            <span class="tab-text">@Loc[nameof(Dialogs.GenAIEvaluationsTabText)]</span>
                                            <Badge>@Content.Evaluations.Count</Badge>
                                        </Header>
                                    </DeckTab>
                                }
                                <DeckTab LabelClass="tab-label"
                                         Id="@($"tab-overview-{OverviewViewKind.Details}")"
                                         Label="@Loc[nameof(Dialogs.GenAIDetailsTabText)]"
                                         Icon="DeckIconName.Info">
                                </DeckTab>
                            </DeckTabs>
                        </div>
                        @if (OverviewActiveView == OverviewViewKind.InputOutput)
                        {
                            <div class="tab-container">
                                @if (!string.IsNullOrEmpty(Content.DisplayErrorMessage))
                                {
                                    <div class="display-error-message">
                                        <h5>@Loc[nameof(Dialogs.GenAIDisplayErrorMessageText)]</h5>
                                        <div class="display-error-content">
                                            @Content.DisplayErrorMessage
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @if (Content.NoMessageContent)
                                    {
                                        <div class="no-message-content-content">
                                            @((MarkupString)string.Format(CultureInfo.CurrentCulture, Loc[nameof(Dialogs.GenAINoMessageContentMoreInformationMessage)], "https://aka.ms/aspire/telemetry-ai-content"))
                                        </div>
                                    }
                                    @RenderMessageSection(Loc[nameof(Dialogs.GenAIInputHeaderText)], Content.InputMessages, Content.NoMessageContent)
                                    @RenderMessageSection(Loc[nameof(Dialogs.GenAIOutputHeaderText)], Content.OutputMessages, Content.NoMessageContent)
                                    @if (Content.ErrorItem is { } errorItem)
                                    {
                                        @RenderMessageSection(Loc[nameof(Dialogs.GenAIErrorHeaderText)], [errorItem], Content.NoMessageContent)
                                    }
                                }
                            </div>
                        }
                        @if (OverviewActiveView == OverviewViewKind.Details)
                        {
                            <div class="tab-container">
                                <SpanDetails ViewModel="@Content.SpanDetailsViewModel" HideToolbar="true" />
                            </div>
                        }
                        @if (OverviewActiveView == OverviewViewKind.Tools)
                        {
                            <div class="tab-container">
                                @if (Content.ToolDefinitions.Count > 0)
                                {
                                    <Accordion Class="tools-list">
                                        @foreach (var toolVM in Content.ToolDefinitions.Where(t => t.ToolDefinition.Type == "function").OrderBy(t => t.ToolDefinition.Name, StringComparer.OrdinalIgnoreCase))
                                        {
                                            <AccordionItem Id="@toolVM.ElementId" Class="@(toolVM.Highlighted ? "tool-highlighted" : null)" @bind-Expanded="toolVM.Expanded" HeadingTooltip="@GetToolHeadingTooltip(toolVM)">
                                                <HeadingTemplate>
                                                    <div class="tool-heading">
                                                        <Badge Tone="accent" style="min-width: 80px; text-align: center;">
                                                            @toolVM.ToolDefinition.Type
                                                        </Badge>
                                                        <span class="tool-name">@toolVM.ToolDefinition.Name</span>
                                                    </div>
                                                </HeadingTemplate>
                                                <ChildContent>
                                                    @if (!string.IsNullOrEmpty(toolVM.ToolDefinition.Description))
                                                    {
                                                        <div class="tool-description">
                                                            <MarkdownRenderer MarkdownProcessor="@_markdownProcess" Markdown="@toolVM.ToolDefinition.Description" />
                                                        </div>
                                                        <hr />
                                                    }
                                                    @if (toolVM.ToolDefinition.Parameters is { Properties: { Count: > 0 } properties })
                                                    {
                                                        <table class="tool-parameters-table">
                                                            <thead>
                                                                <tr>
                                                                    <th class="tool-cell tool-cell-nowrap">@Loc[nameof(Dialogs.GenAIToolParameterName)]</th>
                                                                    <th class="tool-cell tool-cell-nowrap">@Loc[nameof(Dialogs.GenAIToolParameterType)]</th>
                                                                    <th class="tool-cell">@Loc[nameof(Dialogs.GenAIToolParameterDescription)]</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var prop in properties)
                                                                {
                                                                    <tr>
                                                                        <td class="tool-cell tool-cell-nowrap">
                                                                            <strong>@prop.Key</strong>
                                                                            @if (toolVM.ToolDefinition.Parameters.Required?.Contains(prop.Key) == true)
                                                                            {
                                                                                <span style="color: var(--error);"> *</span>
                                                                            }
                                                                        </td>
                                                                        <td class="tool-cell">
                                                                            @if (GenAISchemaHelpers.ConvertTypeToNames(prop.Value) is { Count: > 0 } types)
                                                                            {
                                                                                @* Put each type in its own nowrap element *@
                                                                                for (var i = 0; i < types.Count; i++)
                                                                                {
                                                                                    var typeName = types[i];
                                                                                    if (i < types.Count - 1)
                                                                                    {
                                                                                        typeName += ",";
                                                                                    }
                                                                                    <code class="type-name">@typeName</code>
                                                                                }
                                                                            }
                                                                            else
                                                                            {
                                                                                <span class="empty-data"></span>
                                                                            }
                                                                        </td>
                                                                        <td class="tool-cell">
                                                                            @if (prop.Value.Description is { Length: > 0 } description)
                                                                            {
                                                                                @description
                                                                            }
                                                                            else
                                                                            {
                                                                                <span class="empty-data"></span>
                                                                            }
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                        @if (toolVM.ToolDefinition.Parameters.Required?.Count > 0)
                                                        {
                                                            <div class="tool-footer">
                                                                <span style="color: var(--error);">*</span> @Loc[nameof(Dialogs.GenAIToolRequiredParameter)]
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div class="tool-footer">@Loc[nameof(Dialogs.GenAIToolNoParameters)]</div>
                                                    }
                                                </ChildContent>
                                            </AccordionItem>
                                        }
                                    </Accordion>
                                }
                                else
                                {
                                    <p>@Loc[nameof(Dialogs.GenAINoTools)]</p>
                                }
                            </div>
                        }
                        @if (OverviewActiveView == OverviewViewKind.Evaluations)
                        {
                            <div class="tab-container">
                                @* Don't need to check for empty collection because tab is only displayed if there are evaluations *@
                                @foreach (var evaluation in Content.Evaluations)
                                {
                                    <div class="evaluation-container">
                                        <div class="evaluation-header">
                                            @evaluation.Name
                                            <Divider Class="evaluation-divider" />
                                            @(evaluation.ScoreValue is { } value ? FormatHelpers.FormatNumberWithOptionalDecimalPlaces(value, maxDecimalPlaces: 3) : Loc[nameof(Dialogs.GenAINAText)])
                                            <Divider Class="evaluation-divider" />
                                            @(evaluation.ScoreLabel is { Length: > 0 } label ? label : Loc[nameof(Dialogs.GenAINAText)])
                                        </div>
                                        @if (evaluation.Explanation is { Length: > 0 } explanation)
                                        {
                                            <div>
                                                @explanation
                                            </div>
                                        }
                                        else
                                        {
                                            <div>
                                                <span class="empty-data"></span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </Panel2>
        </FluentSplitter>
    </div>
</FluentDialogBody>

<FluentDialogFooter Visible="false" />

@{
    RenderFragment RenderMessageSection(string title, List<GenAIItemViewModel> items, bool noMessageContent)
    {
        return@<div class="section-container">
            <div class="section-title">@title</div>
            @if (items.Count > 0)
            {
                foreach (var item in items)
                {
                    var itemParts = item.ItemParts.Where(p => !string.IsNullOrEmpty(p.TextVisualizerViewModel.Text)).ToList();

                    <div class="message-container" id="@($"genai-message-{item.Index}")">
                        @if (item.Type != GenAIItemType.Error)
                        {
                            <div class="message-title">
                                <GenAIItemTitle Item="@item" ResourceName="@item.ResourceName" ShowIcon="false" />
                            </div>
                        }
                        <span class="defaultHidden">
                            <button type="button" class="icon-btn" @onclick="@(() => OnViewItem(item))">
                                <DeckIcon Name="DeckIconName.SlideSearch" Size="16" />
                            </button>
                        </span>
                        @if (itemParts.Count > 0)
                        {
                            foreach (var itemPart in itemParts)
                            {
                                if (itemPart.ErrorMessage is not null)
                                {
                                    <div class="error-message-text">@itemPart.ErrorMessage</div>
                                }

                                // Don't display text if it is a copy of the error message
                                if (itemPart.ErrorMessage != itemPart.TextVisualizerViewModel.Text)
                                {
                                    <TextVisualizer ViewModel="@itemPart.TextVisualizerViewModel" HideLineNumbers="true" Virtualize="false" />
                                }
                            }
                        }
                        else
                        {
                            <div class="no-message-content">
                                @Loc[nameof(Dialogs.GenAINoMessageContent)]
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <p>@Loc[nameof(Dialogs.GenAINoMessages)]</p>
            }
        </div>;
    }
}
