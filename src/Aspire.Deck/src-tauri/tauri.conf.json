{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aspire Deck",
  "version": "0.1.0",
  "identifier": "com.microsoft.aspire.deck",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "Aspire Deck",
        "width": 1440,
        "height": 920,
        "minWidth": 920,
        "minHeight": 600,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A native dashboard for .NET Aspire",
    "longDescription": "Aspire Deck is a native, GPU-accelerated dashboard for .NET Aspire. It is a drop-in replacement for the Blazor dashboard's inter-process communication: it hosts the same OTLP ingestion endpoints and speaks the same resource-service gRPC protocol."
  }
}
