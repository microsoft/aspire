{
  "$schema": "./test-selection-rules.schema.json",

  "ignore": [
    ".editorconfig",
    ".gitignore",
    "**/*.md",
    "docs/**",
    "eng/pipelines/**",
    "eng/test-configuration.json",
    "eng/testing/**",
    ".github/workflows/**",
    ".github/actions/**",
    ".github/instructions/**",
    ".github/skills/**",
    ".github/extensions/**",
    ".github/policies/**",
    ".github/aw/**",
    ".agents/**",
    ".vscode/**",
    ".mcp.json",
    "localhive.sh",
    "localhive.ps1",
    "tests/agent-scenarios/**",
    "eng/scripts/test-selection-rules.schema.json",
    "eng/scripts/debug-*.ps1",
    "eng/scripts/debug-*.sh",
    "eng/scripts/cli-starter-validation*.ps1",
    "**/api/*.txt",
    "*.sln",
    "*.slnx",
    "*.slnf"
  ],

  "runEverything": [
    "global.json",
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
    "NuGet.config"
  ],

  "testProjectPatterns": {
    "include": ["tests/**/*.Tests.csproj"],
    "exclude": ["tests/testproject/**", "tests/**/TestFixtures/**", "tests/TestingAppHost1/**"]
  },

  "mappings": [
    {
      "from": "playground/**",
      "to": "tests/Aspire.Playground.Tests/Aspire.Playground.Tests.csproj"
    },
    {
      "from": [
        "src/Aspire.ProjectTemplates/**",
        "tests/Aspire.Templates.Tests/**",
        "tests/Shared/TemplatesTesting/**",
        "tests/Shared/Playwright/**",
        "tests/Shared/InstallSdk.props",
        "tests/Shared/InstallSdk.targets",
        "tests/Shared/Aspire.Templates.Testing.props",
        "tests/Shared/Aspire.Templates.Testing.targets",
        "tests/Shared/EmptyProject.proj",
        "tests/Shared/nuget-with-package-source-mapping.config",
        "tests/workloads.proj",
        "tests/Directory.Build.props",
        "tests/Directory.Build.targets",
        "Directory.Build.props",
        "Directory.Build.targets",
        "eng/Versions.props",
        "global.json"
      ],
      "to": "tests/Aspire.Templates.Tests/Aspire.Templates.Tests.csproj"
    },

    {
      "from": "tests/Aspire.Hosting.CodeGeneration.TypeScript.JsTests/**",
      "to": "tests/Aspire.Hosting.CodeGeneration.TypeScript.JsTests/Aspire.Hosting.CodeGeneration.TypeScript.JsTests.csproj"
    },

    {
      "from": [
        "tests/Infrastructure.Tests/**",
        "eng/Publishing.props",
        "eng/Signing.props",
        "eng/scripts/pack-cli-npm-package.ps1",
        "eng/scripts/stage-native-cli-tool-packages.ps1",
        "eng/scripts/verify-cli-npm-package.ps1",
        "eng/scripts/validate-cli-symbols.ps1",
        "tools/TypeScriptApiCompat/**"
      ],
      "to": "tests/Infrastructure.Tests/Infrastructure.Tests.csproj"
    },

    {
      "from": [
        "eng/scripts/get-aspire-cli.ps1",
        "eng/scripts/get-aspire-cli.sh",
        "eng/scripts/get-aspire-cli-pr.ps1",
        "eng/scripts/get-aspire-cli-pr.sh",
        "eng/scripts/verify-cli-archive.ps1",
        "eng/homebrew/**",
        "eng/winget/**",
        "tests/Aspire.Acquisition.Tests/**"
      ],
      "to": "tests/Aspire.Acquisition.Tests/Aspire.Acquisition.Tests.csproj"
    },

    {
      "from": [
        "eng/scripts/update-aspire-skills-bundle.ps1",
        "eng/scripts/verify-aspire-skills-bundle.ps1"
      ],
      "to": "tests/Aspire.Cli.Tests/Aspire.Cli.Tests.csproj"
    }
  ],

  "edges": [
    {
      "from": [
        "src/Aspire.Cli/**",
        "src/Aspire.Hosting/**",
        "eng/clipack/**"
      ],
      "to": "tests/Aspire.Cli.EndToEnd.Tests/Aspire.Cli.EndToEnd.Tests.csproj",
      "type": "runtime",
      "category": "cli_e2e",
      "exclude": [
        "**/*.md",
        "**/api/*.txt"
      ]
    },
    {
      "from": [
        "tests/Aspire.Cli.EndToEnd.Tests/**",
        "tests/Shared/Hex1b*"
      ],
      "to": "tests/Aspire.Cli.EndToEnd.Tests/Aspire.Cli.EndToEnd.Tests.csproj",
      "type": "build",
      "category": "cli_e2e",
      "exclude": [
        "**/*.md",
        "**/api/*.txt"
      ]
    }
  ],

  "packageOrArchiveProducingProjects": [
    "eng/clipack/**"
  ],

  "inferDeps": {
    "tests/Aspire.Acquisition.Tests/Aspire.Acquisition.Tests.csproj": false,
    "tests/Infrastructure.Tests/Infrastructure.Tests.csproj": false,
    "tests/Aspire.Cli.EndToEnd.Tests/Aspire.Cli.EndToEnd.Tests.csproj": false
  },

  "jobCategories": {
    "extension": {
      "when": [
        "extension/**",
        "src/Aspire.Hosting/**"
      ],
      "exclude": [
        "**/api/*.txt"
      ]
    },

    "polyglot": {
      "when": [
        ".github/workflows/polyglot-validation/**",
        ".github/workflows/polyglot-validation.yml",
        "tests/PolyglotAppHosts/**",
        "src/Aspire.Hosting/**",
        "src/Aspire.Hosting.JavaScript/**",
        "src/Aspire.Hosting.TypeScript/**",
        "src/Aspire.Hosting.Python/**",
        "src/Aspire.Hosting.Go/**",
        "src/Aspire.Hosting.Java/**",
        "src/Aspire.Hosting.Rust/**",
        "src/Aspire.Hosting.CodeGeneration*/**"
      ],
      "exclude": [
        "**/api/*.txt"
      ]
    },

    "integrations": {
      "when": [
        "src/Aspire.Dashboard/**",
        "src/Aspire.Hosting/**",
        "src/Aspire.Hosting.*/**",
        "src/Aspire.*/**",
        "src/Components/**",
        "src/Shared/**",
        "src/Vendoring/**",
        "tests/Aspire.*.Tests/**",
        "tests/Shared/**",
        "tests/Aspire.TestUtilities/**",
        "tests/Aspire.Components.Common.TestUtilities/**",
        "tests/testproject/**",
        "tests/TestingAppHost1/**"
      ],
      "exclude": [
        "src/Aspire.ProjectTemplates/**",
        "src/Aspire.Cli/**",
        "tests/Aspire.Templates.Tests/**",
        "tests/Aspire.Cli.EndToEnd.Tests/**",
        "tests/Aspire.EndToEnd.Tests/**",
        "tests/Aspire.Acquisition.Tests/**",
        "tests/Infrastructure.Tests/**",
        "**/*.md",
        "**/api/*.txt"
      ]
    }
  }
}
