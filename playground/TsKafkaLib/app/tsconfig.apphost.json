{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist/apphost",
    "rootDir": ".."
  },
  "include": [
    "apphost.ts",
    ".modules/**/*.ts",
    "../packages/aspire-kafka/src/**/*.ts",
    "../packages/aspire-kafka/.modules/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
