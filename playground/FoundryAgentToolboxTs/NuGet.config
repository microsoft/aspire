<?xml version="1.0" encoding="utf-8"?>
<!--
  TEMPORARY. Points Aspire.Hosting.Foundry and Aspire.Hosting.JavaScript at the locally-built
  artifacts directory because this playground exercises the polyglot authorizationToken / headers
  API on FoundryToolboxMcpToolOptions, which is not yet in a shipped release.

  Once microsoft/aspire PR #17742 ships, drop this file and reset both packages in
  aspire.config.json back to the empty-string convention used by playground/TypeScriptAppHost.

  See README.md for the local pack + restore workflow.
-->
<configuration>
  <packageSources>
    <add key="local-artifacts" value="..\..\artifacts\packages\Debug\Shipping" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="local-artifacts">
      <package pattern="Aspire.Hosting.Foundry" />
      <package pattern="Aspire.Hosting.JavaScript" />
      <package pattern="Aspire.Hosting.DevTunnels" />
      <package pattern="Aspire.Hosting.Azure.AppContainers" />
    </packageSource>
  </packageSourceMapping>
</configuration>
