<?xml version="1.0" encoding="utf-8"?>
<!-- Local NuGet.config override for the FoundryHostedAgents playground.
     This adds nuget.org as a source so that the latest Microsoft Agent Framework
     packages (Microsoft.Agents.AI.Foundry.Hosting, Azure.AI.Projects, etc.)
     can be resolved. -->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="Microsoft.Agents*" />
      <package pattern="Azure.AI*" />
      <package pattern="ModelContextProtocol*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
