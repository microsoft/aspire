@page "/weather"
@attribute [StreamRendering]
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<Weather> Logger

<PageTitle>Weather</PageTitle>

<h1>Weather</h1>

<p>This component demonstrates showing data.</p>

@if (forecasts == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Temp. (C)</th>
                <th>Temp. (F)</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in forecasts)
            {
                <tr>
                    <td>@forecast.Date.ToShortDateString()</td>
                    <td>@forecast.TemperatureC</td>
                    <td>@forecast.TemperatureF</td>
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private WeatherForecast[]? forecasts;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Weather page initialized - starting to fetch weather data");
        
        try
        {
            var client = HttpClientFactory.CreateClient("weatherapi");
            Logger.LogDebug("Created HTTP client for weather API");
            
            forecasts = await client.GetFromJsonAsync<WeatherForecast[]>("weatherforecast");
            
            Logger.LogInformation("Successfully loaded {ForecastCount} weather forecasts", forecasts?.Length ?? 0);
            
            if (forecasts != null && forecasts.Length > 0)
            {
                var hottest = forecasts.MaxBy(f => f.TemperatureC);
                var coldest = forecasts.MinBy(f => f.TemperatureC);
                Logger.LogInformation("Temperature range: {Coldest}°C to {Hottest}°C", 
                    coldest?.TemperatureC, hottest?.TemperatureC);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load weather forecasts");
            throw;
        }
    }

    private class WeatherForecast
    {
        public DateOnly Date { get; set; }
        public int TemperatureC { get; set; }
        public string? Summary { get; set; }
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);
    }
}
