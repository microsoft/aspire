// Aspire VS Code extension launch configurations
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/extension"
			],
			"outFiles": [
				"${workspaceFolder}/extension/dist/**/*.js"
			],
			"preLaunchTask": "extension: watch",
			"cwd": "${workspaceFolder}/extension"
		},
		{
			"name": "Run Extension (cli stop on entry)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/extension"
			],
			"outFiles": [
				"${workspaceFolder}/extension/dist/**/*.js"
			],
			"preLaunchTask": "extension: watch",
			"env": {
				"ASPIRE_CLI_STOP_ON_ENTRY": "true"
			},
			"cwd": "${workspaceFolder}/extension"
		},
		{
			"name": "Run Extension (apphost stop on entry)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/extension"
			],
			"outFiles": [
				"${workspaceFolder}/extension/dist/**/*.js"
			],
			"preLaunchTask": "extension: watch",
			"env": {
				"ASPIRE_APPHOST_STOP_ON_ENTRY": "true"
			},
			"cwd": "${workspaceFolder}/extension"
		},
		{
			"name": "Run Extension (apphost AND cli stop on entry)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/extension"
			],
			"outFiles": [
				"${workspaceFolder}/extension/dist/**/*.js"
			],
			"preLaunchTask": "extension: watch",
			"env": {
				"ASPIRE_CLI_STOP_ON_ENTRY": "true",
				"ASPIRE_APPHOST_STOP_ON_ENTRY": "true"
			},
			"cwd": "${workspaceFolder}/extension"
		},
		{
			"name": ".NET Core Attach",
			"type": "coreclr",
			"request": "attach",
			"processId": "${command:pickProcess}"
		},
		{
			"name": "Attach to Aspire MCP server",
			"type": "coreclr",
			"request": "attach",
			"processId": "${command:pickProcess}",
			"justMyCode": false
		}
	]
}
