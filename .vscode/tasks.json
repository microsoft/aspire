// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: install extension dependencies",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/ensure-extension-dependencies.js"
			],
			"options": {
				"cwd": "${workspaceFolder}/extension"
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "tasks: watch extension",
			"dependsOrder": "sequence",
			"dependsOn": [
				"npm: install extension dependencies",
				"npm: watch extension"
			],
			"problemMatcher": []
		},
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$ts-webpack-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "npm: watch extension",
			"path": "extension",
		},
		{
			"type": "npm",
			"script": "watch-tests",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build",
			"label": "npm: watch-tests extension",
			"path": "extension",
		},
		{
			"label": "tasks: watch-tests extension",
			"dependsOn": [
				"npm: watch",
				"npm: watch-tests"
			],
			"problemMatcher": [],
			"path": "extension"
		}
	]
}
